# GitHub Models API — same as StoryTime-Generator
# https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=your_github_token_here

# Optional: Hugging Face — image generation for flashcards (https://huggingface.co/settings/tokens)
# HF_TOKEN=
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Optional: Wikimedia Commons — identify your app (https://meta.wikimedia.org/wiki/User-Agent_policy)
# WIKIMEDIA_CONTACT=https://your-site-or-repo
# COMMONS_REQUEST_DELAY=0.35

# Optional: Pexels — modern stock photos (free API key: https://www.pexels.com/api/)
# PEXELS_API_KEY=
# PEXELS_REQUEST_DELAY=0.25

# Optional overrides
# API_ENDPOINT=https://models.github.ai/inference
# MODEL_NAME=openai/gpt-4o-mini
